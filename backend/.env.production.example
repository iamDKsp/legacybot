# ============================================================
# Legacy CRM — Variáveis de Ambiente de PRODUÇÃO
# Copie este arquivo, preencha os valores e configure
# no painel do Railway (não commite o arquivo preenchido!)
# ============================================================

# ── Banco de Dados (Railway PostgreSQL — injetado automaticamente) ────────────
DATABASE_URL=postgresql://USER:PASS@HOST:PORT/DATABASE   # <- Railway injeta isso
DB_HOST=                                                  # <- Railway injeta
DB_PORT=5432
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=

# ── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://SEU-PROJETO.vercel.app   # <- URL exata da Vercel (sem barra no final)

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=GERE_UMA_STRING_ALEATORIA_DE_64_CHARS_AQUI
JWT_EXPIRES_IN=7d

# ── Google Gemini AI ──────────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=AIzaSy...
GOOGLE_AI_MODEL=gemini-3.1-flash-lite-preview
GOOGLE_AI_MEDIA_MODEL=gemini-2.5-flash

# ── WhatsApp Bridge ───────────────────────────────────────────────────────────
WHATSAPP_API_URL=https://SEU-BRIDGE.railway.app   # <- URL pública do bridge no Railway
WHATSAPP_API_KEY=legacy-evolution-api-key-2026
WHATSAPP_INSTANCE=legacy-crm
WEBHOOK_SECRET=legacy-webhook-secret-2026
