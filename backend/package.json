{
    "name": "legacy-crm-backend",
    "version": "1.0.0",
    "description": "Backend API for Legacy CRM - Legal Advisory Platform",
    "main": "dist/server.js",
    "scripts": {
        "dev": "nodemon -e ts,js,json --exec \"ts-node --transpile-only src/server.ts\"",
        "build": "tsc",
        "start": "node dist/server.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "db:migrate": "ts-node src/scripts/migrate.ts",
        "db:seed": "ts-node src/scripts/seed.ts",
        "db:reset": "ts-node src/scripts/reset.ts"
    },
    "dependencies": {
        "@google/generative-ai": "^0.21.0",
        "@types/multer": "^2.1.0",
        "@types/pdfkit": "^0.17.6",
        "axios": "^1.13.5",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^7.4.1",
        "helmet": "^7.2.0",
        "jsonwebtoken": "^9.0.2",
        "knex": "^3.1.0",
        "mammoth": "^1.12.0",
        "morgan": "^1.10.0",
        "multer": "^2.1.1",
        "pdf-parse": "^2.4.5",
        "pdfkit": "^0.18.0",
        "pg": "^8.13.3",
        "socket.io": "^4.8.1",
        "uuid": "^10.0.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/morgan": "^1.9.9",
        "@types/node": "^22.9.0",
        "@types/pg": "^8.20.0",
        "@types/uuid": "^10.0.0",
        "nodemon": "^3.1.7",
        "ts-node": "^10.9.2",
        "typescript": "^5.6.3",
        "vitest": "^2.1.8"
    }
}
